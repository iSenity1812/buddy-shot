/// Relation: User → many RefreshTokens (one per device session)

model RefreshToken {
  id       String @id @default(uuid())
  userId   String @map("user_id")
  deviceId String @map("device_id")

  /// Stores bcrypt hash of the raw token — never store raw token
  tokenHash String @unique @map("token_hash")

  /// Revoked tokens are kept for audit trail (not deleted immediately)
  isRevoked Boolean @default(false) @map("is_revoked")

  /// Hard expiry — cron job cleans up expired rows
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  device Device @relation(fields: [deviceId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([deviceId])
  @@index([expiresAt]) // for cleanup cron
  @@map("refresh_tokens")
}

{
  "extends": "@repo/typescript-config/base.json",
  "compilerOptions": {
    "lib": ["ES2022"],
    "outDir": "./dist",
    "strictNullChecks": true,
    "target": "es2022",
    "rootDir": "src",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    },
    "types": ["module"],
    "module": "esnext",
    "moduleResolution": "node"
  },
  "exclude": ["node_modules", "dist"],
  "include": ["src"]
}
